{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "Stage": {
      "Type": "String",
      "Default": "prod"
    }
  },
  "Conditions": {
    "IsProd": {
      "Fn::Equals": [ { "Ref": "Stage" }, "prod" ]
    }
  },
  "Resources": {
    "Queue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "KmsMasterKeyId": "alias/aws/sqs",
        "DelaySeconds": { "Fn::Length" : [
            { "Fn::If": ["IsProd", "q4", "q5" ] },
            "q1",
            "q2" ]
          }
        }
      }
    }
}