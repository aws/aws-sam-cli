{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "PasswordParameter": {
      "Type": "String",
      "Default": "SecretPa$$"
    }
  },
  "Resources": {
    "CloudFormationCreatedSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": {
        "Name": "MySecret",
        "SecretString": {
          "Fn::ToJsonString": [
            {
              "password": { "Ref": "PasswordParameter" },
              "secretToken": "123"
            },
            {
              "password": { "Ref": "AWS::NoValue" },
              "secretToken": "456"
            }
          ]
        }
      }
    }
  }
}
