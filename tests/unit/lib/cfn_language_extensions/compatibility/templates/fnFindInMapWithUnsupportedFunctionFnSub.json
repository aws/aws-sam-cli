{
  "Mappings": {
    "MapName": {
      "TopKey": {
        "Queue": "Value"
      }
    }
  },
  "Resources": {
    "Queue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "Queue"
      }
    },
    "Cluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Fn::FindInMap": [
            "MapName",
            {
              "Fn::Sub": [
                "${QueueName}",
                {
                  "QueueName": {
                    "Fn::GetAtt": [
                      "Queue",
                      "QueueName"
                    ]
                  }
                }
              ]
            },
            "Queue",
            {"DefaultValue": "Cluster0"}
          ]
        }
      }
    }
  }
}