{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Resources": {
    "CloudFormationCreatedSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": {
        "Name": "MySecret",
        "SecretString": {
          "Fn::ToJsonString": {
            "split": { "Fn::Split": [
              "|",
              { "Ref": "UndefinedParam" }
            ] }
          }
        }
      }
    }
  }
}
