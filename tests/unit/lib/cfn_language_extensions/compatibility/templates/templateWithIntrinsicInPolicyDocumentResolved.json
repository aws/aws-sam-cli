{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Conditions": {
    "RunLambdaInVPC": {
      "Fn::Equals": [ 3, 3 ]
    }
  },
  "Resources": {
    "LambdaRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "Tags": [
          {
            "Key": "cfn",
            "Value": "condition"
          },
          {
            "Key": "already",
            "Value": "exists"
          }
        ],
        "Policies": [
          {
            "PolicyDocument": {
              "Statement": [
                {
                  "Action": [
                    "ec2:CreateNetworkInterface",
                    "ec2:DescribeNetworkInterfaces",
                    "ec2:DeleteNetworkInterface"
                  ],
                  "Effect": "Allow",
                  "Resource": "*"
                }
              ],
              "Version": "2012-10-17"
            }
          }
        ]
      }
    }
  }
}