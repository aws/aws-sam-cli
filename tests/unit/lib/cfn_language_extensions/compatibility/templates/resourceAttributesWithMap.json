{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Parameters": {
    "Region": {
      "Type": "String",
      "Default": "us-west-1"
    }
  },
  "Mappings" : {
    "RegionMap" : {
      "us-east-1" : {
        "$RESOURCE_ATTRIBUTE": "Retain"
      },
      "us-west-1" : {
        "$RESOURCE_ATTRIBUTE": "Delete"
      }
    }
  },
  "Resources": {
    "WaitHandle": {
      "Type": "AWS::CloudFormation::WaitConditionHandle",
      "$RESOURCE_ATTRIBUTE": {
        "Fn::FindInMap" : [
          "RegionMap",
          { "Ref" :  "Region" },
          "$RESOURCE_ATTRIBUTE"
        ]
      }
    }
  }
}
