{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Parameters": {
    "MyParam": {
      "Type": "String",
      "Default": "G"
    }
  },
  "Mappings": {
    "A": {
      "B": {
        "C": "Hello"
      }
    }
  },
  "Conditions": {
    "FalseCondition": {
      "Fn::Equals": [
        "true",
        "false"
      ]
    }
  },
  "Resources": {
    "MyTopic": {
      "Condition": "FalseCondition",
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": {
          "Fn::If": [
            "FalseCondition",
            {
              "Ref": "Undefined"
            },
            {
              "Fn::FindInMap": [
                "A",
                {"Ref": "MyParam"},
                "C",
                {
                  "DefaultValue": {"Ref":  "Undefined"}
                }
              ]
            }
          ]
        }
      }
    }
  }
}
