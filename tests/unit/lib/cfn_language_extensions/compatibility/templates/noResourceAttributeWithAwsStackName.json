{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Conditions": {
    "IsInternalAccount": {
      "Fn::Or": [
        { "Fn::Equals": [ { "Ref": "AWS::AccountId" }, "unit-test-account-id" ] },
        { "Fn::Equals": [ { "Ref": "AWS::AccountId" }, "456" ] },
        { "Fn::Equals": [ { "Ref": "AWS::AccountId" }, "789" ] }
      ]
    }
  },
  "Resources": {
    "Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": { "Fn::If": ["IsInternalAccount", "Name1", { "Ref" :  "AWS::StackName" } ] }
      }
    }
  }
}
