{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "MyQueueList": {
      "Type": "CommaDelimitedList",
      "Default": "1,2"
    }
  },
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    },
    "Topic1": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic1"
      }
    },
    "Topic2": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic2"
      }
    }
  },
  "Outputs": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      {"Ref": "MyQueueList"},
      {
        "Output${VariableName}": {
          "Description": "MyDescription",
          "Value": {"Fn::Sub": "Topic${VariableName}"}
        }
      }
    ]
  }
}
