{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    },
    "Topic1": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic1"
      }
    },
    "Topic2": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic2"
      }
    }
  },
  "Outputs": {
    "Fn::ForEach::Instances": [
      "VariableName",
      [
        1,
        true
      ],
      {
        "Output${VariableName}": {
          "Description": "MyDescription",
          "Value": {"Fn::Sub": "Topic${VariableName}"}
        }
      }
    ]
  }
}
