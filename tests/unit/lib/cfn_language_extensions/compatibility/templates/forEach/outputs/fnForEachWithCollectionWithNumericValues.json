{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  },
  "Outputs": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      [1, 2],
      {
        "Output${VariableName}": {
          "Description": "MyDescription",
          "Value": {"Fn::Sub": "Topic${VariableName}"}
        }
      }
    ]
  }
}
