{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Parameters": {
    "ValueList": {
      "Type": "CommaDelimitedList",
      "Default": "1,0"
    },
    "IdentifierString": {
      "Type": "String",
      "Default": "LogicalId"
    }
  },
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    },
    "Topic1": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic1"
      }
    },
    "Topic2": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic2"
      }
    }
  },
  "Outputs": {
    "Fn::ForEach::UniqueLoopName": [
      [{"Ref": "IdentifierString"}, "TopicId"],
      [
        {"Ref": "ValueList"},
        [2, 1],
        [3, 2]
      ],
      {
        "Output${LogicalId}": {
          "Description": "MyDescription",
          "Value": {"Fn::Sub": "Topic${TopicId}"}
        }
      }
    ]
  }
}