{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  },
  "Outputs": {
    "Fn::ForEach::UniqueLoopName": [
      "param1",
      ["1"],
      {
        "Output${param1}": {
          "Description": "MyDescription",
          "Value": {"Fn::Sub": "Topic${param1}"}
        },
        "Fn::ForEach::UniqueLoopName2": [
          "param2",
          ["A"],
          {
            "Output${param1}${param2}": {
              "Description": "MyDescription",
