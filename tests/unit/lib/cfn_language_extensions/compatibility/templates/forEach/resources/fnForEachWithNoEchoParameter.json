{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "NoEchoList": {
      "Type": "CommaDelimitedList",
      "NoEcho": true
    }
  },
  "Resources": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      {"Ref": "NoEchoList"},
      {
        "Topic${VariableName}": {
          "Type": "AWS::SNS::Topic",
          "Properties": {
            "TopicName": {
              "Fn::Sub": "MyTopic${VariableName}"
            }
          }
        }
      }
    ],
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  }
}
