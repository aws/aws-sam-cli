{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Resources": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      ["1", "2"],
      {
        "Topic${VariableName}${UndefinedValue}": {
          "Type": "AWS::SNS::Topic",
          "Properties": {
            "TopicName": {
              "Fn::Sub": "MyTopic${VariableName}"
            }
          }
        }
      }
    ]
  }
}
