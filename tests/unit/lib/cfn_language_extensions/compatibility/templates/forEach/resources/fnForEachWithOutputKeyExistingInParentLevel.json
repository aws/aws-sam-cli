{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Resources": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      ["1", "2"],
      {
        "SameName${VariableName}": {
          "Type": "AWS::SNS::Topic",
          "Properties": {
            "TopicName": {
              "Fn::Sub": "MyTopic${VariableName}"
            }
          }
        }
      }
    ],
    "SameName1": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic1"
      }
    }
  }
}
