{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "ParamName": {
      "Type": "String",
      "Default": "ABC"
    }
  },
  "Resources": {
    "Fn::ForEach::ParamName": [
      "VariableName",
      ["1", "2"],
      {
        "Topic${VariableName}": {
          "Type": "AWS::SNS::Topic",
          "Properties": {
            "TopicName": {
              "Fn::Sub": "MyTopic${VariableName}"
            }
          }
        }
      }
    ]
  }
}
