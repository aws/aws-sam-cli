{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Resources": {
    "Fn::ForEach::Instances": [
      ["LogicalId"],
      [
        [1, "ami-id1"],
        [2, "ami-id2"],
        [3, "ami-id3"]
      ],
      {
        "${LogicalId}": {
          "Type": "AWS::EC2::Instance",
          "Properties": {
            "DisableApiTermination": true,
            "ImageId": {
              "Ref": "LogicalId"
            },
            "InstanceType": "m5.2xlarge"
          }
        }
      }
    ]
  }
}