{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Resources": {
    "Fn::ForEach::UniqueLoopName": [
      {"Ref": "AWS::NoValue"},
      ["1", "2"],
      {
        "Topic${VariableName}": {
          "Type": "AWS::SNS::Topic",
          "Properties": {
            "TopicName": {
              "Fn::Sub": "MyTopic${VariableName}"
            }
          }
        }
      }
    ],
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  }
}
