{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Conditions": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      ["1", "2", {"Ref": "DoesNotExistValue"}],
      {
        "Condition${VariableName}": {
          "Fn::Equals": ["1", {"Ref": "VariableName"}]
        }
      }
    ]
  },
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  }
}
