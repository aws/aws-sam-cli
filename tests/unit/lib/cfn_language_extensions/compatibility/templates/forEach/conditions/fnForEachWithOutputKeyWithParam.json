{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Parameters": {
    "ParamName": {
      "Type": "String",
      "Default": "ABC"
    }
  },
  "Conditions": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      ["1", "2"],
      {
        "Condition${VariableName}${ParamName}": {
          "Fn::Equals": ["1", {"Ref": "VariableName"}]
        }
      }
    ],
    "Condition0": {
      "Fn::Equals": ["1", "0"]
    }
  },
  "Resources": {
    "Topic0": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic0"
      }
    }
  }
}
