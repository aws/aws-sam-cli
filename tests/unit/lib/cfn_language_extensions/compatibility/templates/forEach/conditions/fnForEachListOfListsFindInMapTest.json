{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Mappings": {
    "Buckets": {
      "Properties": {
        "Identifiers": [1, "3"]
      }
    }
  },
  "Conditions": {
    "Fn::ForEach::UniqueLoopName": [
      ["LogicalId", "TopicId"],
      [
        {"Fn::FindInMap": ["Buckets", "Properties", "Identifiers"]},
        [2, "4"],
        [3, "5"]
      ],
      {
        "Condition${LogicalId}": {
          "Fn::Equals": ["1", {"Ref": "TopicId"}]
        }
      }
    ]
  },
  "Resources": {
    "Topic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic"
      }
    }
  }
}