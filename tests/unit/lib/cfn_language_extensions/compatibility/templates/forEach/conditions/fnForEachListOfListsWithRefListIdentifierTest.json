{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Parameters": {
    "MyQueueList": {
      "Type": "CommaDelimitedList",
      "Default": "AmiId,TopicId"
    }
  },
  "Conditions": {
    "Fn::ForEach::UniqueLoopName": [
      ["LogicalId", {"Ref": "MyQueueList"}],
      [
        [1, "3"],
        [2, "4"],
        [3, "5"]
      ],
      {
        "Condition${LogicalId}": {
          "Fn::Equals": ["1", {"Ref": "TopicId"}]
        }
      }
    ]
  },
  "Resources": {
    "Topic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic"
      }
    }
  }
}