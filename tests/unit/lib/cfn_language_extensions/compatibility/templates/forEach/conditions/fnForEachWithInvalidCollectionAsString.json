{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Conditions": {
    "Fn::ForEach::UniqueLoopName": [
      "VariableName",
      "123",
      {
        "Condition${VariableName}": {
          "Fn::Equals": ["1", {"Ref": "VariableName"}]
        }
      }
    ]
  },
  "Resources": {
    "Topic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic"
      }
    }
  }
}
