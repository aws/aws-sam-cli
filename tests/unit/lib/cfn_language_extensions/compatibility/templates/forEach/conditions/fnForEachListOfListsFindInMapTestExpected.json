{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Mappings": {
    "Buckets": {
      "Properties": {
        "Identifiers": [1, "3"]
      }
    }
  },
  "Conditions": {
    "Condition1": {
      "Fn::Equals": ["1", "3"]
    },
    "Condition2": {
      "Fn::Equals": ["1", "4"]
    },
    "Condition3": {
      "Fn::Equals": ["1", "5"]
    }
  },
  "Resources": {
    "Topic": {
      "Type": "AWS::SNS::Topic",
      "Properties": {
        "TopicName": "MyTopic"
      }
    }
  }
}