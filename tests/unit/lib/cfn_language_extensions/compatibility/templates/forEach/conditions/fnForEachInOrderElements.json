{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Transform": "AWS::LanguageExtensions",
  "Parameters": {
    "InstanceList": {
      "Type": "CommaDelimitedList",
      "Default": "InstanceA,InstanceB,InstanceC"
    }
  },
  "Resources": {
    "Instance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "InstanceType": "t3.medium",
        "ImageId": "ami-00ad2436e75246bba",
        "DisableApiTermination": false
      }
    }
  },
  "Conditions": {
    "Fn::ForEach::UniqueLoopName1": [
      "VariableName1",
      ["1", "2"],
      {
        "Condition${VariableName1}": {
          "Fn::Equals": ["1", {"Ref": "VariableName1"}]
        }
      }
    ],
    "Condition0": {
      "Fn::Equals": ["1", "0"]
    },
    "Fn::ForEach::UniqueLoopName2": [
      "VariableName",
      ["3", "4"],
      {
        "Condition${VariableName}": {
          "Fn::Equals": ["1", {"Ref": "VariableName"}]
        }
      }
    ]
  }
}
