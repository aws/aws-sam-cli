{
  "AWSTemplateFormatVersion" : "2010-09-09",
  "Transform": "LanguageExtensionsDev",
  "Parameters": {
    "queues": {
      "Type": "CommaDelimitedList",
      "Default": "m4.large,m4.xlarge,m4.2xlarge"
    }
  },
  "Conditions": {
    "Has3InstanceType": {
      "Fn::Equals": [ { "Fn::Length": { "Ref": "queues" } }, 3 ]
    }
  },
  "Resources": {
    "Queue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "DelaySeconds": { "Fn::Length" : { "Ref": "queues" } }
      }
    }
  }
}
