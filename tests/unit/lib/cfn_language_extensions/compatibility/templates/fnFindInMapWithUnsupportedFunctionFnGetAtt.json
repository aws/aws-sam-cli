{
  "Mappings": {
    "MapName": {
      "TopKey": {
        "Queue": "Value"
      }
    }
  },
  "Resources": {
    "Queue": {
      "Type": "AWS::SQS::Queue",
      "Properties": {
        "QueueName": "Queue"
      }
    },
    "Cluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": {
          "Fn::FindInMap": [
            "MapName",
            "TopKey",
            {
              "Fn::GetAtt": [
                "Queue",
                "QueueName"
              ]
            },
            {"DefaultValue": "Cluster0"}
          ]
        }
      }
    }
  }
}